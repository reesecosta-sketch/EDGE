# Frontend env (Next.js). Copy to `.env.local` and fill to enable LIVE data.
# The app works WITHOUT these — it renders illustrative sample data until they're set.
#
# ONLY public values belong here. NEVER put the Supabase service-role key or any
# odds/stats API key in the frontend — those are server-side (worker) secrets.
# On Netlify, set these in Site settings → Environment variables instead of committing.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
