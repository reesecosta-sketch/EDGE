# Copy to .env and fill. NEVER commit .env. Rotate any key that has ever been shared.

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key                 # safe for the browser (web/)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key # SERVER-SIDE ONLY (worker/). Never ship to the client.
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Odds data (see research/tech-stack.md: credits != requests) ---
ODDS_API_KEY=your-the-odds-api-key
ODDS_API_BASE=https://api.the-odds-api.com/v4

# --- Optional stats sources ---
CFBD_API_KEY=
BALLDONTLIE_API_KEY=

# --- Web (Next.js public vars mirror the two safe values above) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
